# ============================================
# Frontend Environment Variables
# ============================================
# This file shows the required environment variables for the frontend.
# Copy this file to .env and fill in the actual values.
# DO NOT commit .env to version control!
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# Note: Only variables prefixed with VITE_ are exposed to the frontend
# at build time. Other variables are NOT accessible in the browser.

# AI Backend API URL
# This should be the Lambda Function URL from your backend deployment
# Example: https://abcd1234.lambda-url.us-east-1.on.aws/
VITE_AI_API_URL=

# Location Detection API URL (via API Gateway)
# This should be the API Gateway /location endpoint from your backend deployment
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com/prod/location
VITE_LOCATION_API_URL=

# Optional: Add any other public configuration here
# VITE_APP_VERSION=1.0.0
# VITE_ENABLE_ANALYTICS=false

