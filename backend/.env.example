# ============================================
# Backend Environment Variables (Optional)
# ============================================
# These variables are used during local testing and deployment.
# They are NOT needed in the Lambda environment as they're configured
# in template.yaml.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# DO NOT commit .env to version control!

# AWS Configuration (for local development/deployment)
# AWS_PROFILE=your-aws-profile
# AWS_REGION=us-east-1

# SAM Deployment Configuration
# STACK_NAME=portfolio-ai-backend
# S3_BUCKET=your-deployment-bucket

# Note: Runtime environment variables (BEDROCK_MODEL_ID, ALLOWED_ORIGIN)
# are configured in template.yaml and automatically set in Lambda.
